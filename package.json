{
  "name": "pi-minions",
  "version": "0.1.0",
  "private": true,
  "description": "Delegate tasks to specialized subagents with isolated context. Single, parallel, chain, and pipeline modes with tier-based model routing.",
  "keywords": [
    "pi-package"
  ],
  "license": "MIT",
  "author": "dvictor357",
  "files": [
    "extensions/",
    "package.json",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "npm run typecheck && npm run format:check && npm run test"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": ">=0.79.0",
    "@earendil-works/pi-agent-core": ">=0.79.0",
    "@earendil-works/pi-coding-agent": ">=0.79.0",
    "@earendil-works/pi-tui": ">=0.79.0",
    "@types/node": "^22.0.0",
    "prettier": "^3.3.0",
    "tsx": "^4.22.4",
    "typebox": ">=1.2.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  }
}
